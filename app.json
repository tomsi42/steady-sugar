{
  "expo": {
    "name": "SugarWise",
    "slug": "sugar-wise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "SugarWise needs access to your photos to attach images to food entries.",
          "cameraPermission": "SugarWise needs access to your camera to take photos for food entries."
        }
      ],
      "expo-sharing"
    ]
  }
}
